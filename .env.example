# =============================================================================
# SRE bot Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Configuration
# =============================================================================
# Provider: "openai" or "anthropic"
LLM_PROVIDER=openai

# OpenAI Configuration (if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o

# Anthropic Configuration (if LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# LLM Parameters
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# =============================================================================
# Input Sources (Feature Flags)
# =============================================================================
# Enable/disable webhook receiver
ENABLE_WEBHOOK=true
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000

# Enable/disable Slack event listener
ENABLE_SLACK_LISTENER=true

# =============================================================================
# Slack Configuration
# =============================================================================
# Bot Token (xoxb-...) - required for posting messages
SLACK_BOT_TOKEN=xoxb-your-bot-token

# App Token (xapp-...) - required for Socket Mode (real-time events)
SLACK_APP_TOKEN=xapp-your-app-token

# Signing Secret - for verifying webhook requests
SLACK_SIGNING_SECRET=your-signing-secret

# Channel to monitor for alerts
SLACK_ALERT_CHANNEL=alerts

# =============================================================================
# Observability Stack
# =============================================================================
# Local development with Kind cluster (NodePort):
PROMETHEUS_URL=http://localhost:9090
LOKI_URL=http://localhost:3100
TEMPO_URL=http://localhost:3200

# Inside Kubernetes cluster (ClusterIP):
# PROMETHEUS_URL=http://prometheus-prometheus.monitoring.svc.cluster.local:9090
# LOKI_URL=http://loki-gateway.monitoring.svc.cluster.local:80
# TEMPO_URL=http://tempo.monitoring.svc.cluster.local:3200

# =============================================================================
# GitHub Configuration
# =============================================================================
# Personal Access Token with repo read permissions
GITHUB_TOKEN=ghp_your-github-token

# Default organization for repository lookups
# If not set, service name must include org (e.g., "myorg/myservice")
GITHUB_ORG=your-org

# =============================================================================
# Database Configuration
# =============================================================================
# SQLite for development
DATABASE_URL=sqlite+aiosqlite:///./sre_bot.db

# PostgreSQL for production
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sre_bot

# =============================================================================
# Timeouts
# =============================================================================
# Timeout for observability queries (seconds)
QUERY_TIMEOUT_SECONDS=30.0

# Timeout for LLM API calls (seconds)
LLM_TIMEOUT_SECONDS=60.0

# =============================================================================
# Investigation Parameters
# =============================================================================
# How far back to look for metrics/logs/traces (minutes)
LOOKBACK_MINUTES=30

# Consider deploys within this window as "recent" (hours)
RECENT_DEPLOY_HOURS=2
